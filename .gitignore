# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Compiled output ──────────────────────────────────────────────────────────
dist
tmp
out-tsc
*.tsbuildinfo

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules

# ── Expo / React Native ──────────────────────────────────────────────────────
.expo
.expo-shared

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE / editors ────────────────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Misc build artefacts ─────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# ── System files ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Replit-specific ──────────────────────────────────────────────────────────
# These directories are managed by the Replit platform and contain
# platform-specific state that should not be committed to Git.
.cache/
.local/
.agents/

# ── Session / chat artefacts in attached_assets ──────────────────────────────
# Files created when pasting prompts or uploading screenshots into the Replit
# AI chat. They are session-specific and not part of the project.
attached_assets/Pasted-*.txt
attached_assets/*.jpg
attached_assets/*.jpeg
attached_assets/*.png
attached_assets/*.webp
attached_assets/generated_images/

# ── Replit Nx / GitHub Copilot instructions (not project docs) ───────────────
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
