# ══════════════════════════════════════════════════════════════════════════════
# WavesOfEgypt — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# Lines marked (required) must be set. Lines marked (optional) have sensible
# defaults and can be omitted.
# ══════════════════════════════════════════════════════════════════════════════


# ── Database (required) ───────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Replit: provisioned automatically via the PostgreSQL integration.
DATABASE_URL=postgresql://user:password@localhost:5432/wavesofegypt


# ── API Server ────────────────────────────────────────────────────────────────

# TCP port the API server listens on. (optional, default: 8080)
PORT=8080

# Pino log level: fatal | error | warn | info | debug | trace (optional)
LOG_LEVEL=info

# Runtime environment. Set to "production" in deployed environments. (optional)
NODE_ENV=development


# ── Email — booking confirmation (optional) ───────────────────────────────────
#
# All SMTP_* variables are optional. When unset, the server logs a warning and
# skips email sending — bookings still work, users just won't receive emails.
# Any SMTP provider (Gmail, Mailgun, Resend SMTP, Brevo, etc.) works.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# "From" address shown in confirmation emails. (optional)
SMTP_FROM=bookings@wavesofegypt.com


# ── Web App — Vite (build-time) ───────────────────────────────────────────────

# URL base path for the Vite app.
# Use "/" for Vercel, Netlify, or any host where the site lives at the root.
# On Replit this is set automatically by the artifact proxy system.
BASE_PATH=/

# Public URL of the deployed API server. Required when the web app and API
# are hosted on different domains (e.g. Vercel frontend + Railway API).
# Leave unset when running locally (relative /api/* paths are used instead).
# Example: https://wavesofegypt-api.up.railway.app
VITE_API_URL=


# ── API Server — CORS ─────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for CORS.
# Unset or "*" → allow all (fine for development).
# In production, restrict this to your Vercel domain(s).
# Example: https://wavesofegypt.vercel.app,https://wavesofegypt.com
CORS_ORIGIN=


# ── Mobile App — Expo ─────────────────────────────────────────────────────────

# Domain (host only, no protocol) where the API server is reachable from the
# mobile app. Used as: https://${EXPO_PUBLIC_DOMAIN}/api/...
# Development example: localhost:8080
# Production example:  api.wavesofegypt.com
EXPO_PUBLIC_DOMAIN=localhost:8080


# ── Replit-specific (auto-injected on Replit, ignore on other hosts) ──────────
#
# These are injected automatically by the Replit runtime. Do not set them
# manually unless you know what you are doing.
#
# REPL_ID=
# REPLIT_DEV_DOMAIN=
# REPLIT_EXPO_DEV_DOMAIN=
